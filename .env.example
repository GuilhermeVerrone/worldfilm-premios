# =============================================
# BACKEND
# =============================================

# Database
DATABASE_URL=mysql://user:password@localhost:3306/worldfilm_dev

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-64-chars-here-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-64-chars-here-change-in-production

# Server
PORT=3001
NODE_ENV=development

# Firebase Admin SDK — caminho para o arquivo service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json

# File uploads
UPLOAD_PATH=./uploads

# =============================================
# WEB (Vite)
# =============================================

VITE_API_URL=http://localhost:3001
VITE_APP_ENV=development
